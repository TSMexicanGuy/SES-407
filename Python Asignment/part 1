# this code is for part 1 of the python assignment
#it will generate 20 random integers between 1 and 100 and categorize them as odd or even
import random       #import random
import numpy as np #import array 

size = 20   #amount of numbers to generate
vec = np.zeros(size, dtype=int) #initilize vector with zeros

for i in range(size):
    vec[i] = random.randint(1,100) #generates random numbers and puts them in array
    
vec2 = vec % 2 #modulus calcuates remainder after division, 0 is even 1 is odd

evens = np.array([]) #list to hold even numbers
odds = np.array([])  #list to hold odd numbers
           
for i in range(size):
    if vec2[i] == 0:     #if moduus is zero then put it into the evens array
        evens = np.append(evens, vec[i])   #append add the number to the end of the array
    else:                                   #all other elements must be odd if not even
        odds = np.append(odds, vec[i])

print("evens:    ",evens) #prints the output
print("odds:      ",odds)













