import pandas as pd
import matplotlib.pyplot as plt


data = pd.read_csv('Python Asignment/O_chem_data (1).csv')
print(data)

temp = data['Temperature[C]']
temp = temp.values

ethanol = data['ethanol-ethylene']
propanol = data['propanol-propene']
but = data['butanol-butene']
pent = data['pentonal-pentene']
hex = data['hexanol-hexene']
hept = data['heptanol-heptene']
oct = data['octanol-octene']


plt.plot(temp,ethanol.values,label = 'ethanol-ethylene')
plt.plot(temp,propanol.values,label = 'propanol-propene')
plt.plot(temp,but.values,label = 'butanol-butene')
plt.plot(temp,pent.values,label = 'pentanol-pentene')
plt.plot(temp,hex.values,label = 'hexanol-hexene')
plt.plot(temp,hept.values,label = 'heptanol-heptene')
plt.plot(temp,oct.values,label = 'octanol-octene')

plt.xlabel('Temp °C')
plt.ylabel('log concentration')
plt.legend()
plt.title('Alcohol to Alkene Dehydration Reactions')
plt.grid()
plt.show()

